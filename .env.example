# K8s Migration Tool - Environment Configuration
# Copy this file to .env and adjust values for your environment

# Backend server port
PORT=8080

# Log level: info | debug | warn | error
LOG_LEVEL=info

# Path to local k3d kubeconfigs (for development)
SOURCE_KUBECONFIG_PATH=infra/kubeconfigs/source-kubeconfig.yaml
TARGET_KUBECONFIG_PATH=infra/kubeconfigs/target-kubeconfig.yaml

# Frontend dev server port
FRONTEND_PORT=5173

# Maximum resources per migration job (0 = unlimited)
MAX_RESOURCES_PER_JOB=0
